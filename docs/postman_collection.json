{
  "info": {
    "_postman_id": "sbp-api-v1-collection",
    "name": "Service Booking Platform API",
    "description": "Complete Postman collection for the Service Booking Platform REST API v1. All endpoints organized by module. Set the `baseUrl` and `accessToken` collection variables before running.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"9876543210\"\n}"
            }
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));"] } }]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "const json = pm.response.json();",
              "if (json.data && json.data.accessToken) {",
              "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
              "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
              "}"
            ]}
          }]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] },
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"John Updated\",\n  \"phone\": \"9123456789\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Services",
      "item": [
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/services/categories", "host": ["{{baseUrl}}"], "path": ["services", "categories"] }
          }
        },
        {
          "name": "List Services",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/services?category_id=1&limit=10&page=1",
              "host": ["{{baseUrl}}"], "path": ["services"],
              "query": [
                { "key": "category_id", "value": "1", "disabled": true },
                { "key": "limit", "value": "10" },
                { "key": "page", "value": "1" }
              ]
            }
          }
        },
        {
          "name": "Get Service by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/services/1", "host": ["{{baseUrl}}"], "path": ["services", "1"] }
          }
        },
        {
          "name": "Create Service (Admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/services", "host": ["{{baseUrl}}"], "path": ["services"] },
            "body": { "mode": "raw", "raw": "{\n  \"category_id\": 1,\n  \"name\": \"Pipe Leak Repair\",\n  \"description\": \"Fix pipe leaks in kitchen and bathroom\",\n  \"price\": 799.00,\n  \"duration_minutes\": 60\n}" }
          }
        },
        {
          "name": "Update Service (Admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/services/1", "host": ["{{baseUrl}}"], "path": ["services", "1"] },
            "body": { "mode": "raw", "raw": "{\n  \"category_id\": 1,\n  \"name\": \"Pipe Leak Repair (Updated)\",\n  \"price\": 899.00,\n  \"duration_minutes\": 90\n}" }
          }
        },
        {
          "name": "Delete Service (Admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/services/1", "host": ["{{baseUrl}}"], "path": ["services", "1"] }
          }
        }
      ]
    },
    {
      "name": "Time Slots",
      "item": [
        {
          "name": "List Time Slots (by service)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/timeslots?service_id=1",
              "host": ["{{baseUrl}}"], "path": ["timeslots"],
              "query": [{ "key": "service_id", "value": "1" }]
            }
          }
        },
        {
          "name": "List All Time Slots",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/timeslots", "host": ["{{baseUrl}}"], "path": ["timeslots"] }
          }
        },
        {
          "name": "Create Time Slot (Admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/timeslots", "host": ["{{baseUrl}}"], "path": ["timeslots"] },
            "body": { "mode": "raw", "raw": "{\n  \"service_id\": 1,\n  \"start_time\": \"2026-04-10T10:00:00.000Z\",\n  \"end_time\": \"2026-04-10T11:00:00.000Z\"\n}" }
          }
        },
        {
          "name": "Toggle Slot Availability (Admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/timeslots/1", "host": ["{{baseUrl}}"], "path": ["timeslots", "1"] },
            "body": { "mode": "raw", "raw": "{\n  \"is_available\": false\n}" }
          }
        },
        {
          "name": "Delete Time Slot (Admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/timeslots/1", "host": ["{{baseUrl}}"], "path": ["timeslots", "1"] }
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create Booking (User)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] },
            "body": { "mode": "raw", "raw": "{\n  \"service_id\": 1,\n  \"booking_time\": \"2026-04-10T10:00:00.000Z\",\n  \"notes\": \"Please bring all tools\"\n}" }
          }
        },
        {
          "name": "Get My Bookings (User)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/bookings/my", "host": ["{{baseUrl}}"], "path": ["bookings", "my"] }
          }
        },
        {
          "name": "Get All Bookings (Admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
          }
        },
        {
          "name": "Get Booking by ID",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/bookings/1", "host": ["{{baseUrl}}"], "path": ["bookings", "1"] }
          }
        },
        {
          "name": "Update Booking Status (Admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/bookings/1/status", "host": ["{{baseUrl}}"], "path": ["bookings", "1", "status"] },
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"Confirmed\"\n}" }
          }
        },
        {
          "name": "Reschedule Booking (User)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/bookings/1/reschedule", "host": ["{{baseUrl}}"], "path": ["bookings", "1", "reschedule"] },
            "body": { "mode": "raw", "raw": "{\n  \"booking_time\": \"2026-04-12T14:00:00.000Z\"\n}" }
          }
        },
        {
          "name": "Assign Staff (Admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/bookings/1/assign", "host": ["{{baseUrl}}"], "path": ["bookings", "1", "assign"] },
            "body": { "mode": "raw", "raw": "{\n  \"staff_id\": 1,\n  \"notes\": \"Technician will arrive at 10 AM\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Staff",
      "item": [
        {
          "name": "Get All Staff",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/staff", "host": ["{{baseUrl}}"], "path": ["staff"] }
          }
        },
        {
          "name": "Get Staff Roles",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/staff/roles", "host": ["{{baseUrl}}"], "path": ["staff", "roles"] }
          }
        },
        {
          "name": "Create Staff (Admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/staff", "host": ["{{baseUrl}}"], "path": ["staff"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Ramesh Kumar\",\n  \"email\": \"ramesh@company.com\",\n  \"password\": \"password123\",\n  \"phone\": \"9876540001\",\n  \"role_id\": 3\n}" }
          }
        },
        {
          "name": "Delete Staff (Admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/staff/1", "host": ["{{baseUrl}}"], "path": ["staff", "1"] }
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Add Service Review (User)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/reviews/service", "host": ["{{baseUrl}}"], "path": ["reviews", "service"] },
            "body": { "mode": "raw", "raw": "{\n  \"booking_id\": 1,\n  \"rating\": 5,\n  \"comment\": \"Excellent service, very professional!\"\n}" }
          }
        },
        {
          "name": "Add User Review (Staff)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/reviews/user", "host": ["{{baseUrl}}"], "path": ["reviews", "user"] },
            "body": { "mode": "raw", "raw": "{\n  \"booking_id\": 1,\n  \"rating\": 4,\n  \"comment\": \"Customer was cooperative and on time.\"\n}" }
          }
        },
        {
          "name": "Get Reviews by Service",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/reviews/service/1", "host": ["{{baseUrl}}"], "path": ["reviews", "service", "1"] }
          }
        }
      ]
    }
  ]
}
